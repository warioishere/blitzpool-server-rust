  "db_name": "PostgreSQL",
  "query": "SELECT\n            \"deletedAt\" AS \"deleted_at?\",\n            \"createdAt\" AS \"created_at!\",\n            \"updatedAt\" AS \"updated_at!\",\n            id AS \"id!\",\n            address AS \"address!: AddressId\",\n            \"time\" AS \"time!\",\n            reason AS \"reason!\",\n            count AS \"count!\",\n            shares AS \"shares!\"\n           FROM client_rejected_statistics_entity\n           WHERE \"deletedAt\" IS NULL AND address = $1 AND \"time\" >= $2\n           ORDER BY \"time\" ASC",
