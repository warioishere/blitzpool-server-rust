  "query": "SELECT\n            \"deletedAt\" AS \"deleted_at?\",\n            \"createdAt\" AS \"created_at!\",\n            \"updatedAt\" AS \"updated_at!\",\n            id AS \"id!\",\n            \"time\" AS \"time!\",\n            reason AS \"reason!\",\n            count AS \"count!\"\n           FROM pool_rejected_statistics_entity\n           WHERE \"deletedAt\" IS NULL AND \"time\" >= $1\n           ORDER BY \"time\" ASC",
