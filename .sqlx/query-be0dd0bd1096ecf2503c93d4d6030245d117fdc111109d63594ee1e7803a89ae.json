  "query": "SELECT\n            token AS \"token!\",\n            \"groupId\" AS \"group_id!\",\n            address AS \"address!: AddressId\",\n            email AS \"email!\",\n            status AS \"status!\",\n            \"createdAt\" AS \"created_at!\",\n            \"expiresAt\" AS \"expires_at!\",\n            \"respondedAt\" AS \"responded_at?\"\n           FROM blockparty_invitation\n           WHERE \"groupId\" = $1 AND address = $2 AND status = 'pending'\n           LIMIT 1",
