# blitzpool-rust full-setup — environment overrides.
#
# Copy to `.env` (gitignored) and uncomment whatever you need to
# override. `docker compose` reads `.env` from the same directory as
# the compose file automatically.

# ── Postgres ────────────────────────────────────────────────────────
# Default DB name is `blitzpool`. When attaching to an existing TS-pool
# install whose DB is still called `public_pool`, override here:
#PG_DATABASE=public_pool
#PG_USER=postgres
#PG_PASSWORD=postgres

# ── Redis / Valkey ──────────────────────────────────────────────────
#REDIS_PASSWORD=
#REDIS_MAX_MEMORY=4096mb

# ── Pool logging verbosity ──────────────────────────────────────────
#RUST_LOG=info,blitzpool=debug
